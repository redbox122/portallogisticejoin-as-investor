# ربط التطبيق بالسيرفر / Connect app to your server
# انسخ الملف إلى .env أو .env.local وعدّل القيم ثم شغّل: npm start

# تطوير محلي — باك اند Laravel (tasheel-backend)
REACT_APP_API_BASE_URL=http://127.0.0.1:8000/api
REACT_APP_API_ORIGIN=http://127.0.0.1:8000

# إنتاج / ستايجنغ (غيّر عند النشر):
# REACT_APP_API_BASE_URL=https://your-domain.com/api
# REACT_APP_API_ORIGIN=https://your-domain.com
